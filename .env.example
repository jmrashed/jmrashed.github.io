# Next.js
NEXT_PUBLIC_SITE_URL=https://jmrashed.github.io

# Formspree — get your form ID at https://formspree.io
# 1. Sign up at formspree.io
# 2. Create a new form, copy the ID from the endpoint URL
# 3. Paste it here (just the ID, e.g. xpwzgkqb — not the full URL)
NEXT_PUBLIC_FORMSPREE_ID=your-formspree-form-id

